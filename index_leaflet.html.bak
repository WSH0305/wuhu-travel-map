<!DOCTYPE html>
<html lang="zh-CN" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>芜湖市区文旅导览地图</title>
    
    <!-- Leaflet 核心库 -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    
    <!-- 自定义样式 -->
    <link rel="stylesheet" href="css/style.css">
</head>
<body>
    
    <!-- ========== 顶部导航 ========== -->
    <div class="header">
        <div class="header-title">
            <span>🗺️</span>
            芜湖市区文旅导览地图
        </div>
        <div class="header-controls">
            <button class="btn-header" onclick="locateMe()" title="定位到当前位置">
                📍 定位
            </button>
            <button class="btn-header" id="measure-btn" onclick="toggleMeasure()" title="测距工具">
                📏 测距
            </button>
            <button class="btn-header" id="theme-btn" onclick="toggleTheme()">
                🌙 夜间模式
            </button>
        </div>
    </div>
    
    <!-- ========== 地图容器 ========== -->
    <div id="map"></div>
    
    <!-- ========== 搜索框 ========== -->
    <div class="search-box">
        <input type="text" class="search-input" id="search-input" placeholder="🔍 搜索公园、景点、游乐园...">
        <div class="search-results" id="search-results"></div>
    </div>
    
    <!-- ========== 左侧信息面板 ========== -->
    <div class="sidebar">
        <div class="sidebar-header">
            <span>🏞️ 景点导览</span>
            <span style="font-size:12px;color:var(--text-light);">点击景点可定位</span>
        </div>
        <div class="sidebar-content">
            
            <!-- 统计面板 -->
            <div class="stats-panel">
                <div class="stats-title">📊 数据统计</div>
                <div class="stats-grid">
                    <div class="stat-item">
                        <div class="stat-number" id="stat-parks">0</div>
                        <div class="stat-label">🌳 公园</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-number" id="stat-spots">0</div>
                        <div class="stat-label">🏛️ 景点</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-number" id="stat-fun">0</div>
                        <div class="stat-label">🎢 游乐园</div>
                    </div>
                </div>
            </div>
            
            <!-- 分类筛选 -->
            <div class="filter-group">
                <button class="filter-btn active" data-filter="全部" onclick="filterByCategory('全部')">🏠 全部</button>
                <button class="filter-btn" data-filter="公园" onclick="filterByCategory('公园')">🌳 公园</button>
                <button class="filter-btn" data-filter="景点" onclick="filterByCategory('景点')">🏛️ 景点</button>
                <button class="filter-btn" data-filter="游乐园" onclick="filterByCategory('游乐园')">🎢 游乐园</button>
            </div>
            
            <!-- 地点列表 -->
            <div class="place-list" id="place-list">
                <p style="color:var(--text-light);text-align:center;padding:20px;">正在加载数据...</p>
            </div>
            
        </div>
    </div>
    
    <!-- ========== 图例 ========== -->
    <div class="legend">
        <div class="legend-title">🎨 图例</div>
        <div style="font-size:11px;color:var(--text-light);margin-bottom:8px;">💡 右上角可切换底图</div>
        <div class="legend-item">
            <div class="legend-icon" style="background:#2ecc71;"></div>
            <span>🌳 公园</span>
        </div>
        <div class="legend-item">
            <div class="legend-icon" style="background:#f39c12;"></div>
            <span>🏛️ 景点</span>
        </div>
        <div class="legend-item">
            <div class="legend-icon" style="background:#e74c3c;"></div>
            <span>🎢 游乐园</span>
        </div>
    </div>
    
    <!-- ========== JavaScript ========== -->
    <script src="js/main.js"></script>
    
</body>
</html>
